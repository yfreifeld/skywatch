# Copy this to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it's in .gitignore.

aws_region           = "us-east-1"
key_name             = "my-aws-keypair"          # Name of key pair in AWS console
ssh_private_key_path = "~/.ssh/my-aws-keypair.pem"
allowed_ssh_cidr     = "1.2.3.4/32"              # Your public IP (curl ifconfig.me)
instance_type        = "t3.micro"
master_volume_size   = 15
worker_volume_size   = 15
project_name         = "skywatch"
