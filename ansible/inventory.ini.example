[master]
1.2.3.4 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/my-key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[worker]
5.6.7.8 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/my-key.pem ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[all:vars]
master_ip=1.2.3.4
worker_ip=5.6.7.8
